# file_replay, rtsp or active_cameras.
INGESTION_SOURCE_TYPE=file_replay
INGESTION_SOURCE_FILE=samples/cam01.mp4
INGESTION_CAMERA_ID=11111111-1111-1111-1111-111111111111
INGESTION_EXTERNAL_CAMERA_KEY=cam01
INGESTION_ZONE_ID=
INGESTION_FPS=1
INGESTION_MAX_FRAMES=10
INGESTION_REPLAY=true
INGESTION_REPLAY_START_AT=2026-01-01T00:00:00Z

# RTSP live source mode. Use INGESTION_SOURCE_TYPE=rtsp and set
# INGESTION_REPLAY=false for live timestamps/emitted_at.
INGESTION_RTSP_URL=rtsp://127.0.0.1:8554/cam01
INGESTION_RTSP_TRANSPORT=tcp
# Optional: prefer structured config from vigilante_api.api.camera.
# When set, ingestion loads the row by INGESTION_CAMERA_ID and builds the RTSP
# URL in runtime from camera_hostname/camera_port/camera_path/channel/subtype.
INGESTION_CAMERA_DB_URL=
INGESTION_CAMERA_DB_SCHEMA=api
CAMERA_SECRET_FERNET_KEY=

# Active camera supervisor mode. Use INGESTION_SOURCE_TYPE=active_cameras.
# DB is the supported source for this slice. Leave INGESTION_CAMERA_ID empty
# in active_cameras mode to load all active RTSP cameras.
INGESTION_ACTIVE_CAMERA_SOURCE=db
INGESTION_ACTIVE_CAMERA_CONCURRENCY=
INGESTION_ACTIVE_CAMERA_REFRESH_SECONDS=30
INGESTION_ACTIVE_CAMERA_STATUS_INTERVAL_SECONDS=30
INGESTION_ACTIVE_CAMERA_STOP_TIMEOUT_SECONDS=10
INGESTION_ACTIVE_CAMERA_ENABLE_HEALTH_SERVER=false
INGESTION_ACTIVE_CAMERA_HEALTH_HOST=127.0.0.1
INGESTION_ACTIVE_CAMERA_HEALTH_PORT=8088

INGESTION_RTSP_READ_TIMEOUT_SECONDS=10
INGESTION_RTSP_RECONNECT_INITIAL_DELAY_SECONDS=1
INGESTION_RTSP_RECONNECT_MAX_DELAY_SECONDS=30
INGESTION_RTSP_RECONNECT_BACKOFF_MULTIPLIER=2
# Empty means retry forever. Set a number for bounded demos/tests.
INGESTION_RTSP_MAX_RECONNECT_ATTEMPTS=

INGESTION_STORAGE_BACKEND=local
INGESTION_LOCAL_STORAGE_DIR=storage

INGESTION_PUBLISH_MODE=jsonl
INGESTION_OUTBOX_PATH=outbox/frame_ingested.jsonl
INGESTION_OUTBOX_RESET=true

# RabbitMQ publication mode. Use INGESTION_PUBLISH_MODE=rabbitmq or both.
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_FRAME_EXCHANGE=vigilante.frames
RABBITMQ_FRAME_ROUTING_KEY=frame.ingested
RABBITMQ_RECOGNITION_QUEUE=vigilante.recognition.frame_ingested
RABBITMQ_FRAME_DLX=vigilante.frames.dlx
RABBITMQ_FRAME_DLQ=vigilante.recognition.frame_ingested.dlq
RABBITMQ_FRAME_DLQ_ROUTING_KEY=frame.ingested.dlq

# Optional MinIO mode.
INGESTION_MINIO_ENDPOINT=localhost:9000
INGESTION_MINIO_ACCESS_KEY=minio
INGESTION_MINIO_SECRET_KEY=minio123
INGESTION_MINIO_BUCKET=vigilante-frames
INGESTION_MINIO_SECURE=false

# Optional S3-compatible aliases. INGESTION_STORAGE_BACKEND=s3 uses these
# through the same adapter when the INGESTION_MINIO_* values are not set.
INGESTION_S3_ENDPOINT=localhost:9000
INGESTION_S3_ACCESS_KEY=minio
INGESTION_S3_SECRET_KEY=minio123
INGESTION_S3_BUCKET=vigilante-frames
INGESTION_S3_SECURE=false
